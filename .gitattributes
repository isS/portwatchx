# Normalize line endings across platforms
* text=auto eol=lf

# Explicit text
*.md        text
*.json      text
*.ts        text
*.tsx       text
*.js        text
*.yml       text
*.yaml      text

# Windows scripts
*.bat       text eol=crlf
*.ps1       text eol=crlf

# Binaries
*.png       binary
*.jpg       binary
*.ico       binary
*.woff      binary
*.woff2     binary

# Hide generated / vendored files in diffs and GitHub language stats
dist/**     linguist-generated
